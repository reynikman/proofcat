# Owner-machine release state. These files live inside this canonical workspace
# but must NEVER be committed.
.private/
release-artifacts/

# Signing keys must NEVER be committed (kept in .private/ on the owner Mac)
*.key
*.key.pub

# Secrets must NEVER be committed (values live in Infisical / CI-secrets)
.env
.env.*
!.env.example
